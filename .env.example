# ==============================================================================
# Plantilla de Variables de Entorno - AgriTech Backend
# Renombrar a '.env' para desarrollo local
# ==============================================================================

# --- Configuración Básica de Django ---
# Activar modo de depuración en local (True) y desactivar en producción (False)
DEBUG=True

# Clave secreta para criptografía en Django (Generar una fuerte para producción)
SECRET_KEY=django-insecure-development-only-not-for-prod-hackathon-2026

# Hosts permitidos (lista separada por comas)
ALLOWED_HOSTS=localhost,127.0.0.1,*


# --- Configuración de Base de Datos ---
# Formato: engine://usuario:contraseña@servidor:puerto/nombre_bd
# Local Docker Compose:
DATABASE_URL=postgres://postgres:postgres@db:5432/agritech

# Producción GCP (Cloud SQL Auth Proxy o Dirección IP de Cloud SQL):
# DATABASE_URL=postgres://<usuario>:<password>@/agritech?host=/cloudsql/<gcp-project-id>:<location>:<db-instance-name>


# --- Configuración CORS & Seguridad ---
# Permitir llamadas desde cualquier origen (No recomendado para producción)
CORS_ALLOW_ALL_ORIGINS=True

# O configurar orígenes permitidos específicos (separados por comas):
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Orígenes confiables para CSRF (requerido para Django Admin si se despliega en HTTPS)
CSRF_TRUSTED_ORIGINS=https://agritech-service-xxxxxx-uc.a.run.app


# --- Integración con Google Vertex AI ---
# ID de tu proyecto en Google Cloud Platform
GCP_PROJECT_ID=agritech-santa-cruz-bolivia

# Ubicación regional del servicio de Vertex AI (ej: us-central1)
GCP_LOCATION=us-central1

# ID o URL completa del Endpoint del modelo predictivo entrenado a 12 meses
VERTEX_AI_ENDPOINT_ID=1234567890123456789


# --- Integración con Google Gemini (LLM para alertas en lenguaje natural) ---
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo Gemini a utilizar (gemini-1.5-flash es rápido y económico)
GEMINI_MODEL=gemini-1.5-flash


# --- APIs de Datos Climáticos Externos ---
# Open-Meteo (API pública gratuita, sin clave requerida)
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# NASA POWER API (gratuita, sin clave requerida)
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# CHIRPS (datos de precipitación satelital de alta resolución)
CHIRPS_BASE_URL=https://iridl.ldeo.columbia.edu/SOURCES/.UCSB/.CHIRPS


# --- Modo de Operación del Sistema ---
# True = conectar a APIs climáticas reales (Open-Meteo, NASA POWER)
# False = usar datos climáticos simulados realistas (modo desarrollo)
USE_REAL_CLIMATE_DATA=False

# True = usar Gemini para generar alertas en lenguaje natural
# False = usar plantillas de texto predefinidas como fallback
USE_GEMINI_ALERTS=True

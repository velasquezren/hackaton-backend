# ==============================================================================
# Plantilla de Variables de Entorno - AgriTech / CampoIA
# Renombrar a '.env' para desarrollo local
# ==============================================================================

# --- Configuración Básica de Django ---
DEBUG=True
SECRET_KEY=django-insecure-development-only-not-for-prod-hackathon-2026
ALLOWED_HOSTS=localhost,127.0.0.1,*

# --- Base de Datos ---
# Local (Docker Compose):
DATABASE_URL=postgres://postgres:postgres@db:5432/agritech
# Producción GCP (Cloud SQL):
# DATABASE_URL=postgres://<usuario>:<password>@/agritech?host=/cloudsql/<project-id>:<location>:<instance>

# --- CORS & Seguridad ---
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://backend-agritech-698520637534.us-central1.run.app

# --- Google Vertex AI (Predicciones Climáticas a 12 meses) ---
GCP_PROJECT_ID=hackaton-2026-01
GCP_LOCATION=us-central1
VERTEX_AI_ENDPOINT_ID=

# --- Google Gemini (Alertas en lenguaje natural) ---
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Google Earth Engine (Datos Satelitales NDVI/NDWI) ---
# Registrarse en: https://earthengine.google.com/
GEE_PROJECT_ID=hackaton-2026-01

# --- API Climática (Open-Meteo — gratuita, sin clave) ---
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# --- Modos de Operación ---
# False = datos simulados realistas (desarrollo sin internet)
# True  = conectar a APIs reales (producción)
USE_REAL_CLIMATE_DATA=False
USE_REAL_SATELLITE_DATA=False
USE_GEMINI_ALERTS=True
